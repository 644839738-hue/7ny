# ----------------------------------------------------------------
# SpriteForge AI — backend environment configuration
# ----------------------------------------------------------------
# Copy this file to backend/.env and fill in your values.
#   cp backend/.env.example backend/.env
#
# NEVER commit backend/.env to version control.
# ----------------------------------------------------------------

# --- Demo mode ---
# true  = use built-in sample assets (no API key needed)
# false = use the provider specified by IMAGE_PROVIDER
DEMO_MODE=false

# --- Image generation provider (used when DEMO_MODE=false) ---
# demo     = built-in sample assets
# wanxiang = Tongyi Wanxiang / DashScope text-to-image
IMAGE_PROVIDER=wanxiang

# --- DashScope / Tongyi Wanxiang ---
# Get your API key from: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=

# Output size: "1024*1024", "720*1280", "1280*720", etc.
WANXIANG_SIZE=1024*1024

# Number of images per request (1-4)
WANXIANG_N=1

# --- Fallback ---
# When true, automatically fall back to demo provider if AI generation fails
ALLOW_DEMO_FALLBACK=true
